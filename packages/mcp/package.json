{
  "name": "@cue/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing cue capabilities as tools for AI agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cue-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsup src/server.ts src/index.ts --format cjs --dts --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cue/core": "workspace:*",
    "@cue/player": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
