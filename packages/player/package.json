{
  "name": "@cue/player",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone embeddable demo player for cue SDK",
  "main": "dist/cue-player.iife.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
