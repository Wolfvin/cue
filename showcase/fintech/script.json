{
  "id": "bankflow-fintech-demo",
  "title": "BankFlow — Modern Banking, Simplified",
  "steps": [
    {
      "id": "secure-login",
      "duration": 6000,
      "template": {
        "type": "login",
        "data": {
          "brand": "BankFlow",
          "title": "Selamat Datang",
          "subtitle": "Masuk ke akun perbankan Anda",
          "fields": [
            { "name": "email", "type": "email", "label": "Email", "placeholder": "aditya@bankflow.id", "value": "aditya@bankflow.id" },
            { "name": "password", "type": "password", "label": "Kata Sandi", "placeholder": "••••••••••", "value": "••••••••••" }
          ],
          "submitLabel": "Masuk dengan Aman"
        }
      },
      "pointer": { "x": 0.50, "y": 0.62 },
      "hotspots": [
        { "id": "h-login-brand", "x": 0.50, "y": 0.18, "label": "Brand", "alwaysShow": true },
        { "id": "h-login-email", "x": 0.50, "y": 0.40, "label": "Email" },
        { "id": "h-login-pass", "x": 0.50, "y": 0.52, "label": "Kata Sandi" },
        { "id": "h-login-btn", "x": 0.50, "y": 0.65, "label": "Masuk", "alwaysShow": true }
      ],
      "annotations": [
        { "type": "box", "x": 0.28, "y": 0.12, "width": 0.44, "height": 0.72, "color": "#2563EB", "cornerRadius": 12, "label": "Secure Login Form" }
      ],
      "caption": "Login aman dengan autentikasi 2FA — uang Anda terlindungi dari klik pertama."
    },
    {
      "id": "view-balance",
      "duration": 6000,
      "template": {
        "type": "dashboard",
        "data": {
          "title": "Dashboard",
          "greeting": "Selamat datang, Aditya!",
          "columns": 3,
          "metrics": [
            { "label": "Total Saldo", "value": "Rp 142.750.000", "change": "+2.4%", "icon": "💰" },
            { "label": "Tabungan", "value": "Rp 85.200.000", "change": "+1.8%", "icon": "🏦" },
            { "label": "Investasi", "value": "Rp 25.000.000", "change": "+5.2%", "icon": "📈" }
          ]
        }
      },
      "pointer": { "x": 0.25, "y": 0.40 },
      "hotspots": [
        { "id": "h-bal-total", "x": 0.25, "y": 0.40, "label": "Total Saldo", "alwaysShow": true },
        { "id": "h-bal-savings", "x": 0.55, "y": 0.40, "label": "Tabungan" },
        { "id": "h-bal-invest", "x": 0.80, "y": 0.40, "label": "Investasi" }
      ],
      "annotations": [
        { "type": "text", "x": 0.50, "y": 0.20, "text": "Selamat datang, Aditya!", "color": "#ffffff", "fontSize": 16, "align": "center" }
      ],
      "caption": "Semua akun dalam satu tampilan — tabungan, giro, dan investasi terintegrasi."
    },
    {
      "id": "initiate-transfer",
      "duration": 6000,
      "template": {
        "type": "form",
        "data": {
          "title": "Transfer Dana",
          "description": "Kirim uang ke rekening manapun dalam hitungan detik",
          "fields": [
            { "name": "amount", "label": "Jumlah Transfer", "type": "text", "value": "Rp 5.000.000", "required": true },
            { "name": "recipient", "label": "Nama Penerima", "type": "text", "value": "Siti Rahayu" },
            { "name": "account", "label": "Nomor Rekening", "type": "text", "value": "8821-4567-8901" },
            { "name": "bank", "label": "Bank Tujuan", "type": "select", "value": "BCA", "options": ["BCA", "BNI", "BRI", "Mandiri", "BSI"] },
            { "name": "note", "label": "Catatan", "type": "text", "value": "Bantuan bulanan keluarga" }
          ],
          "submitLabel": "Lanjut ke Konfirmasi",
          "layout": "centered"
        }
      },
      "pointer": { "x": 0.50, "y": 0.50 },
      "hotspots": [
        { "id": "h-xfer-amount", "x": 0.50, "y": 0.35, "label": "Jumlah", "alwaysShow": true },
        { "id": "h-xfer-recipient", "x": 0.50, "y": 0.47, "label": "Penerima" },
        { "id": "h-xfer-bank", "x": 0.50, "y": 0.60, "label": "Bank Tujuan" },
        { "id": "h-xfer-btn", "x": 0.50, "y": 0.80, "label": "Lanjutkan", "alwaysShow": true }
      ],
      "annotations": [
        { "type": "arrow", "x1": 0.15, "y1": 0.35, "x2": 0.35, "y2": 0.35, "color": "#2563EB", "label": "Isi otomatis" }
      ],
      "caption": "Transfer dana dalam hitungan detik — isi jumlah, pilih penerima, hampir selesai."
    },
    {
      "id": "confirm-transfer",
      "duration": 6000,
      "template": {
        "type": "table",
        "data": {
          "title": "Konfirmasi Transfer",
          "showRowNumbers": false,
          "columns": [
            { "key": "field", "label": "Detail" },
            { "key": "value", "label": "Informasi" }
          ],
          "rows": [
            { "cells": { "field": "Jumlah", "value": "Rp 5.000.000" } },
            { "cells": { "field": "Penerima", "value": "Siti Rahayu" } },
            { "cells": { "field": "Bank", "value": "BCA — 8821-4567-8901" } },
            { "cells": { "field": "Catatan", "value": "Bantuan bulanan keluarga" } },
            { "cells": { "field": "Biaya", "value": "GRATIS" }, "status": "success" },
            { "cells": { "field": "Estimasi", "value": "Instan (real-time)" }, "status": "success" }
          ]
        }
      },
      "pointer": { "x": 0.50, "y": 0.75 },
      "hotspots": [
        { "id": "h-confirm-amount", "x": 0.60, "y": 0.32, "label": "Jumlah" },
        { "id": "h-confirm-fee", "x": 0.60, "y": 0.62, "label": "Gratis!", "alwaysShow": true },
        { "id": "h-confirm-btn", "x": 0.50, "y": 0.85, "label": "Konfirmasi & Kirim", "alwaysShow": true }
      ],
      "annotations": [
        { "type": "box", "x": 0.15, "y": 0.15, "width": 0.70, "height": 0.72, "color": "#2563EB", "cornerRadius": 12, "label": "Review sebelum kirim" }
      ],
      "caption": "Periksa kembali sebelum mengirim — transparansi penuh atas jumlah, biaya, dan detail penerima."
    },
    {
      "id": "success-notification",
      "duration": 6000,
      "template": {
        "type": "terminal",
        "data": {
          "title": "BankFlow Terminal",
          "cwd": "~/transfer",
          "prompt": "$",
          "lines": [
            { "text": "bankflow transfer --to 8821-4567-8901 --amount 5000000", "type": "command" },
            { "text": "Verifying recipient... OK", "type": "output" },
            { "text": "Checking balance... Sufficient (Rp 142.750.000)", "type": "output" },
            { "text": "Processing transfer...", "type": "output" },
            { "text": "", "type": "output" },
            { "text": "✓ Transfer berhasil!", "type": "success" },
            { "text": "  Ref: BF-20260615-84729", "type": "output" },
            { "text": "  Jumlah: Rp 5.000.000", "type": "output" },
            { "text": "  Biaya: Rp 0 (GRATIS)", "type": "success" },
            { "text": "  Estimasi tiba: Instan", "type": "success" }
          ]
        }
      },
      "pointer": { "x": 0.50, "y": 0.55 },
      "hotspots": [
        { "id": "h-success-ref", "x": 0.45, "y": 0.58, "label": "Nomor Referensi", "alwaysShow": true },
        { "id": "h-success-free", "x": 0.45, "y": 0.68, "label": "Gratis!" },
        { "id": "h-success-instant", "x": 0.45, "y": 0.76, "label": "Instan" }
      ],
      "annotations": [
        { "type": "text", "x": 0.50, "y": 0.10, "text": "Transfer Berhasil!", "color": "#22c55e", "fontSize": 18, "align": "center" }
      ],
      "caption": "Konfirmasi instan dengan nomor referensi — uang Anda sampai dalam hitungan detik."
    },
    {
      "id": "open-account",
      "duration": 5000,
      "template": {
        "type": "login",
        "data": {
          "brand": "BankFlow",
          "title": "Buka Akun Gratis",
          "subtitle": "Bergabung dengan 2 juta+ pengguna yang mempercayai BankFlow",
          "fields": [
            { "name": "fullname", "type": "text", "label": "Nama Lengkap", "placeholder": "Nama lengkap Anda" },
            { "name": "email", "type": "email", "label": "Email", "placeholder": "email@andatoko.id" },
            { "name": "phone", "type": "tel", "label": "Nomor HP", "placeholder": "+62 812 3456 7890" }
          ],
          "submitLabel": "Buka Akun Sekarang",
          "footerLinks": [
            { "label": "Tanpa biaya daftar" },
            { "label": "Proses < 5 menit" },
            { "label": "Deposit awal Rp 0" }
          ]
        }
      },
      "pointer": { "x": 0.50, "y": 0.72 },
      "hotspots": [
        { "id": "h-cta-benefits", "x": 0.50, "y": 0.82, "label": "Tanpa biaya", "alwaysShow": true }
      ],
      "caption": "Bergabung dengan 2 juta+ pengguna — buka akun gratis hari ini, tanpa biaya tersembunyi.",
      "cta": {
        "type": "email_capture",
        "label": "Buka Akun Gratis",
        "placeholder": "Email Anda",
        "submitLabel": "Daftar Sekarang",
        "successMessage": "Selamat! Akun BankFlow Anda sudah aktif."
      }
    }
  ],
  "loop": true,
  "theme": {
    "accent": "#2563EB",
    "bg": "#0a0f1a",
    "font": "'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif"
  }
}
